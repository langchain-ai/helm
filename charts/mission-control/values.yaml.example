# Copy to values.yaml and adjust for your cluster.

# -- Provide a name in place of `mission-control`
nameOverride: ""
# -- String to fully override the chart's full name
fullnameOverride: ""
# -- Namespace to install the chart into. If not set, will use the namespace of the current context.
namespace: <namespace_name>
# -- Annotations that will be applied to all resources created by the chart
commonAnnotations: {}
# -- Annotations that will be applied to all pods created by the chart
commonPodAnnotations: {}
# -- Labels that will be applied to all resources created by the chart
commonLabels: {}

# Application-level configuration. Runtime knobs that gate features, authentication,
# and discovery scope. Infrastructure-level options (images, resources, services,
# storage) stay at the top level outside `config`.
config:
  # Backend API authentication (HTTP Basic Auth). Keep config.auth.enabled=true in production.
  auth:
    enabled: true
    # -- Pre-created Secret with username/password (and optionally JWT signing) keys.
    existingSecret: mission-control-auth
    # -- Key in `existingSecret` holding the basic-auth username.
    usernameKey: username
    # -- Key in `existingSecret` holding the basic-auth password.
    passwordKey: password
    # -- Optional: key in `existingSecret` holding the JWT signing secret.
    # Required when backend.replicas > 1 so all pods can validate each other's tokens.
    # Generate with: openssl rand -base64 32
    jwtSecretKey: ""
    # -- Optional: comma-separated list of origins allowed to make credentialed requests.
    # Required only when the backend and frontend are served from different hostnames.
    allowedOrigins: ""

  # Feature flags. Disabling a flag removes its write verbs from the ClusterRole.
  features:
    # -- Fix Issue button: deletes pods stuck in CreateContainerConfigError. Grants pods:delete.
    fixIssue: true
    # -- Adopt button: patches Helm ownership metadata onto existing resources.
    # Grants secrets/configmaps/serviceaccounts/deployments/statefulsets:patch.
    adopt: true
    # -- Alert notifications (SMTP + webhook). Grants write access to alert-config secrets.
    # Egress: outbound SMTP and webhook to the configured endpoints.
    alerts: true
    # -- Chat assistant: floating widget that proxies to chat.langchain.com.
    # Egress: outbound HTTPS to chat.langchain.com and *.us.langgraph.app.
    chat: true
    # -- Diagnostic bundle download (pod logs + resource manifests packaged as a zip).
    diagnostics: true
    # -- Persists working configuration to the draft Kubernetes Secret.
    configSave: true
    # -- Namespace-scoped infrastructure discovery via the /api/discover endpoint.
    discover: true
    # -- Database detection, preflight checks, and support query execution.
    dbTools: true
    # -- In-browser helm upgrade --install. Set false for read-only installs.
    deploy: true
    # -- Operator-uploaded values.yaml overrides per product (airgapped support).
    # Adds a settings pill in the topbar to download/upload/clear values files;
    # uploads are stored in the `mission-control-values-overrides` Secret and
    # used by /api/values in preference to the live GitHub fetch.
    valuesOverride: true

  # -- Extra namespaces (comma-separated) the discover feature is allowed to scan.
  discoverNamespaces: ""

images:
  # -- If supplied, all child <image>.repository values will be prepended with this registry name + `/`
  registry: ""
  # -- Image pull secrets used by all components.
  imagePullSecrets:
    - name: regcred
  backendImage:
    repository: langchain/mission-control-backend
    pullPolicy: IfNotPresent
    tag: latest
  frontendImage:
    repository: langchain/mission-control-frontend
    pullPolicy: IfNotPresent
    tag: latest

# Backend (FastAPI) component - installed as a StatefulSet.
backend:
  # -- Replica count. Set > 1 only when config.auth.jwtSecretKey is set so all pods validate each other's tokens.
  replicas: 1
  # -- Pod-level security context.
  podSecurityContext: {}
  # -- Container-level security context.
  securityContext: {}
  # -- Additional environment variables passed to the backend container.
  extraEnv: []
  resources:
    requests:
      cpu: 250m
      memory: 256Mi
    limits:
      cpu: 500m
      memory: 512Mi
  service:
    type: ClusterIP
    port: 8000
  serviceAccount:
    # -- When true (default) the chart creates a ServiceAccount, ClusterRole, and ClusterRoleBinding.
    create: true
    # -- Override the generated ServiceAccount name.
    name: ""

# Frontend (static React app served by an HTTP server) component.
frontend:
  replicas: 1
  podSecurityContext: {}
  securityContext: {}
  extraEnv: []
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 200m
      memory: 256Mi
  service:
    type: ClusterIP
    port: 3000

# Optional ingress; disabled by default.
ingress:
  enabled: false
  host: ""

# Diagnostic-bundle storage. Toggles the backend StatefulSet's volumeClaimTemplates.
# Default is emptyDir (bundles lost on pod restart).
#
# Important: `volumeClaimTemplates` is immutable on a StatefulSet. Toggling
# `diagnostics.persistence.enabled` after install requires `helm uninstall` then
# reinstall - Kubernetes does not allow adding or removing claim templates in place.
diagnostics:
  persistence:
    enabled: false
    # -- Leave empty to use the cluster default StorageClass.
    storageClass: ""
    size: 1Gi
    accessMode: ReadWriteOnce
